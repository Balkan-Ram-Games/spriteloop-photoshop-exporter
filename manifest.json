{
  "manifestVersion": 5,
  "id": "dev.spriteloop.photoshop.exporter",
  "name": "SpriteLoop Exporter",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "spriteloopPanel",
      "label": {
        "default": "SpriteLoop"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "assets/panel-icon.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "all"
          ],
          "species": [
            "toolbar"
          ]
        }
      ],
      "minimumSize": {
        "width": 280,
        "height": 260
      },
      "maximumSize": {
        "width": 520,
        "height": 720
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 460
      }
    },
    {
      "type": "command",
      "id": "exportSpriteLoopPackage",
      "label": {
        "default": "Export SpriteLoop Package"
      }
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "assets/plugin-icon.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "all"
      ],
      "species": [
        "pluginList"
      ]
    }
  ]
}
