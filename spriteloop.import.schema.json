{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spriteloop.dev/schema/spriteloop.import.schema.json",
  "title": "SpriteLoop Import Package",
  "type": "object",
  "required": ["format", "version", "canvas", "parts"],
  "properties": {
    "format": {
      "const": "spriteloop.import"
    },
    "version": {
      "const": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": true
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "image", "x", "y", "width", "height"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "image": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "opacity": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "visible": {
            "type": "boolean"
          },
          "parentId": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "hierarchy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "children"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "type": {
            "enum": ["group"]
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

